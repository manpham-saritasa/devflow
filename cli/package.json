{
  "name": "devflow-sync",
  "version": "1.0.0",
  "description": "Sync AI workflow files from devflow to your projects",
  "type": "module",
  "bin": {
    "devflow-sync": "./dist/index.js"
  },
  "files": [
    "dist",
    "content"
  ],
  "scripts": {
    "prebuild": "node scripts/prebuild.js",
